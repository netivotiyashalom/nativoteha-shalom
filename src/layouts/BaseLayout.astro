---
import MaintenanceOverlay from '../components/MaintenanceOverlay.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'נתיבותיה שלום', description = 'דפי מקורות ושיעורי תורה' } = Astro.props;
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title} | נתיבותיה שלום</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;500;700;900&family=Heebo:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <MaintenanceOverlay />
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <span class="logo-he">נתיבותיה שלום</span>
        <span class="logo-sub">דפי מקורות ושיעורי תורה</span>
      </a>
      <nav class="main-nav">
        <a href="/parashiyot">פרשות שבוע</a>
        <a href="/hagim">חגים ומועדים</a>
        <a href="/nosim">נושאים שונים</a>
        <a href="/about">אודות</a>
        <a href="/contact">צור קשר</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', (user) => {
        if (!user) {
          window.netlifyIdentity.on('login', () => {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">נתיבותיה שלום</span>
        <span class="footer-tagline">דפי מקורות ושיעורי תורה</span>
      </div>
      <nav class="footer-nav">
        <a href="/parashiyot">פרשות שבוע</a>
        <a href="/hagim">חגים ומועדים</a>
        <a href="/nosim">נושאים שונים</a>
        <a href="/about">אודות</a>
        <a href="/contact">צור קשר</a>
        <a href="/privacy">פרטיות</a>
      </nav>
      <p class="footer-copy">&copy; {new Date().getFullYear()} נתיבותיה שלום</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue: #1B2E4B;
    --gold: #C9A84C;
    --gold-light: #e8c96a;
    --white: #ffffff;
    --bg: #f9f7f2;
    --text: #1a1a1a;
    --text-muted: #555;
    --border: #e0d8c8;
    --radius: 8px;
    --shadow: 0 2px 12px rgba(27,46,75,0.08);
  }

  html { direction: rtl; }

  body {
    font-family: 'Heebo', 'Frank Ruhl Libre', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2, h3, h4, h5 {
    font-family: 'Frank Ruhl Libre', serif;
    color: var(--blue);
    line-height: 1.3;
  }

  a { color: var(--blue); text-decoration: none; }
  a:hover { color: var(--gold); }

  .site-header {
    background: var(--blue);
    color: var(--white);
    padding: 0 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .site-logo {
    display: flex;
    flex-direction: column;
    color: var(--white);
    text-decoration: none;
  }

  .logo-he {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.5px;
  }

  .logo-sub {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.7);
    font-weight: 300;
  }

  .main-nav {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .main-nav a {
    color: rgba(255,255,255,0.85);
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }

  .main-nav a:hover {
    background: rgba(201,168,76,0.2);
    color: var(--gold-light);
  }

  main { flex: 1; }

  .site-footer {
    background: var(--blue);
    color: rgba(255,255,255,0.6);
    padding: 2rem 1.5rem 1.5rem;
    font-size: 0.85rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .footer-logo {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold);
  }

  .footer-tagline { font-size: 0.78rem; color: rgba(255,255,255,0.5); }

  .footer-nav {
    display: flex;
    gap: 0.2rem 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-nav a {
    color: rgba(255,255,255,0.65);
    font-size: 0.85rem;
    transition: color 0.15s;
  }

  .footer-nav a:hover { color: var(--gold); }

  .footer-copy { font-size: 0.78rem; color: rgba(255,255,255,0.35); text-align: left; }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem clamp(1.5rem, 4vw, 4rem);
  }

  .card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s;
  }

  .card:hover { box-shadow: 0 4px 20px rgba(27,46,75,0.12); }

  .btn {
    display: inline-block;
    padding: 0.55rem 1.4rem;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, transform 0.1s;
  }

  .btn:active { transform: scale(0.98); }

  .btn-primary {
    background: var(--blue);
    color: var(--white);
  }

  .btn-primary:hover { opacity: 0.88; color: var(--white); }

  .btn-gold {
    background: var(--gold);
    color: var(--blue);
  }

  .btn-gold:hover { opacity: 0.88; }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .badge-blue { background: var(--blue); color: var(--white); }
  .badge-gold { background: var(--gold); color: var(--blue); }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--blue);
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--gold);
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr; text-align: center; gap: 1rem; }
    .footer-copy { text-align: center; }
  }

  @media (max-width: 640px) {
    .header-inner { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
    .main-nav { gap: 0.2rem; }
    .main-nav a { font-size: 0.88rem; padding: 0.35rem 0.7rem; }
  }
</style>
