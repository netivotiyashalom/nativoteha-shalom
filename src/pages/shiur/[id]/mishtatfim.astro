---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShiurFeedback from '../../../components/ShiurFeedback.astro';

export async function getStaticPaths() {
  const all = await getCollection('shiurim');
  return all
    .filter(e => e.id.startsWith('mishtatfim/'))
    .map(entry => {
      const shiurId = entry.id.replace('mishtatfim/', '');
      return { params: { id: shiurId }, props: { entry } };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const shiurId = entry.id.replace('mishtatfim/', '');

const all = await getCollection('shiurim');
const meaiverEntry = all.find(e => e.id === `meaiver/${shiurId}`);
---

<BaseLayout
  title={`${entry.data.title} — למשתתפים`}
  description={entry.data.description}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">בית</a> &rsaquo;
      {entry.data.category === 'parasha' && <><a href="/parashiyot">פרשות שבוע</a> &rsaquo;</>}
      {entry.data.category === 'chag'    && <><a href="/hagim">חגים ומועדים</a> &rsaquo;</>}
      {entry.data.category === 'nose'    && <><a href="/nosim">נושאים שונים</a> &rsaquo;</>}
      <span>{entry.data.title}</span>
    </nav>

    <div class="page-switcher">
      <span class="switcher-label">הצג דף:</span>
      {meaiverEntry && (
        <a href={`/shiur/${shiurId}/meaiver`} class="switch-btn">למעביר השיעור</a>
      )}
      <span class="switch-btn active">למשתתפים</span>
    </div>

    <div class="shiur-header card">
      <div class="header-meta">
        <span class="badge badge-gold">דף למשתתפים</span>
        {entry.data.difficulty && (
          <span class="badge badge-blue">{entry.data.difficulty}</span>
        )}
        {entry.data.duration && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            {entry.data.duration}
          </span>
        )}
        {entry.data.tags?.map(t => <span class="tag">{t}</span>)}
      </div>
      <h1>{entry.data.title}</h1>
      <p class="shiur-desc">{entry.data.description}</p>
    </div>

    <div class="shiur-content card prose">
      <Content />
    </div>

    <ShiurFeedback shiurId={shiurId} shiurTitle={entry.data.title} />

    <div class="page-nav">
      <button onclick="window.print()" class="btn btn-primary">הדפסת הדף</button>
      {meaiverEntry && (
        <a href={`/shiur/${shiurId}/meaiver`} class="btn btn-gold">דף למעביר &raquo;</a>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--blue); }

  .page-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .switcher-label { font-size: 0.88rem; color: var(--text-muted); }

  .switch-btn {
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    background: #f0ece2;
    color: var(--blue);
    border: 2px solid transparent;
    text-decoration: none;
    cursor: default;
  }

  a.switch-btn { cursor: pointer; }
  a.switch-btn:hover { border-color: var(--gold); }

  .switch-btn.active { background: var(--gold); color: var(--blue); }

  .shiur-header {
    padding: 1.8rem;
    margin-bottom: 1.5rem;
    border-right: 5px solid var(--gold);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.8rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .tag {
    background: #f0ece2;
    color: var(--blue);
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
    font-size: 0.75rem;
  }

  .shiur-header h1 { font-size: 1.9rem; margin-bottom: 0.4rem; }
  .shiur-desc { color: var(--text-muted); font-size: 0.97rem; }

  /* ── Prose ── */
  .prose {
    padding: 2rem 2.4rem;
    margin-bottom: 1.5rem;
    line-height: 2;
    font-size: 1.04rem;
  }

  .prose :global(h2) {
    font-size: 1.22rem;
    color: var(--blue);
    margin: 2rem 0 0.7rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--gold);
    display: inline-block;
  }

  .prose :global(h3) {
    font-size: 1.05rem;
    color: var(--blue);
    margin: 1.4rem 0 0.5rem;
  }

  .prose :global(p) { margin-bottom: 0.85rem; }

  .prose :global(blockquote) {
    border-right: 4px solid var(--gold);
    padding: 1rem 1.4rem;
    margin: 1.2rem 0;
    background: rgba(201,168,76,0.07);
    border-radius: 0 6px 6px 0;
  }

  .prose :global(blockquote p) {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.9;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-right: 1.4rem;
    margin-bottom: 0.85rem;
  }

  .prose :global(li) { margin-bottom: 0.45rem; }

  .prose :global(strong) { color: var(--blue); font-weight: 700; }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.8rem 0;
  }

  .page-nav {
    display: flex;
    gap: 0.8rem;
    justify-content: flex-start;
    margin-top: 1rem;
  }

  @media print {
    .breadcrumb, .page-switcher, .page-nav, .site-header, .site-footer,
    #maintenance-overlay { display: none !important; }
    .shiur-content { box-shadow: none; border: none; }
    .prose { padding: 0; }
  }

  @media (max-width: 640px) {
    .prose { padding: 1.4rem 1.2rem; }
  }
</style>
