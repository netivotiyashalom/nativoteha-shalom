---
interface Props {
  shiurId: string;
  shiurTitle: string;
  adminEmail?: string;
}
const { shiurId, shiurTitle, adminEmail = 'netivotiyashalom@gmail.com' } = Astro.props;
---

<div class="feedback-section" data-shiur-id={shiurId}>
  <h3 class="feedback-title">משוב לשיעור</h3>

  <div class="feedback-buttons">
    <button
      class="feedback-btn"
      data-type="used"
      data-shiur={shiurId}
      aria-pressed="false"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/>
        <path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
      </svg>
      השתמשתי בשיעור זה
      <span class="feedback-count" data-count-type="used">0</span>
    </button>

    <button
      class="feedback-btn"
      data-type="personal"
      data-shiur={shiurId}
      aria-pressed="false"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
      לימוד אישי
      <span class="feedback-count" data-count-type="personal">0</span>
    </button>
  </div>

  <div class="comment-section">
    <button class="toggle-comment-btn" id={`toggle-comment-${shiurId}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      השאר תגובה פרטית למנהל
    </button>

    <div class="comment-form-wrap" id={`comment-form-${shiurId}`} hidden>
      <form class="comment-form" data-shiur={shiurId} data-title={shiurTitle} data-email={adminEmail}>
        <textarea
          name="comment"
          placeholder="כתוב את התגובה כאן... (תישלח באופן פרטי למנהל)"
          rows="3"
          maxlength="800"
          class="comment-textarea"
        ></textarea>
        <div class="comment-actions">
          <span class="comment-note">* התגובה פרטית ותגיע רק למנהל</span>
          <button type="submit" class="btn btn-primary btn-sm">שלח תגובה</button>
        </div>
      </form>
      <div class="comment-success" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        התגובה נשלחה — תודה!
      </div>
    </div>
  </div>
</div>

<style>
  .feedback-section {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
    margin-top: 2rem;
  }

  .feedback-title {
    font-size: 1rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 1rem;
    font-family: 'Heebo', sans-serif;
  }

  .feedback-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .feedback-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.1rem;
    border: 2px solid var(--border);
    border-radius: 24px;
    background: var(--white);
    color: var(--text-muted);
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.18s;
  }

  .feedback-btn:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  .feedback-btn[aria-pressed="true"] {
    background: var(--blue);
    border-color: var(--blue);
    color: var(--white);
  }

  .feedback-btn[aria-pressed="true"][data-type="personal"] {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--blue);
  }

  .feedback-count {
    background: rgba(255,255,255,0.25);
    border-radius: 12px;
    padding: 0 0.45rem;
    font-size: 0.78rem;
    font-weight: 700;
    min-width: 1.4rem;
    text-align: center;
  }

  .feedback-btn:not([aria-pressed="true"]) .feedback-count {
    background: #e8e4dc;
    color: var(--text-muted);
  }

  .toggle-comment-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0.3rem 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .toggle-comment-btn:hover { color: var(--blue); }

  .comment-form-wrap { margin-top: 0.8rem; }

  .comment-textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.92rem;
    resize: vertical;
    direction: rtl;
    background: var(--white);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
  }

  .comment-textarea:focus { border-color: var(--blue); }

  .comment-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .comment-note {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .btn-sm { padding: 0.4rem 1rem; font-size: 0.88rem; }

  .comment-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #2d7a3a;
    font-size: 0.9rem;
    padding: 0.6rem 0;
  }
</style>

<script>
  function initFeedback() {
    // --- Feedback buttons (localStorage) ---
    document.querySelectorAll<HTMLButtonElement>('.feedback-btn').forEach(btn => {
      const shiurId = btn.dataset.shiur!;
      const type = btn.dataset.type!;
      const key = `feedback_${shiurId}_${type}`;
      const countKey = `feedback_count_${shiurId}_${type}`;

      const isActive = localStorage.getItem(key) === '1';
      const count = parseInt(localStorage.getItem(countKey) ?? '0', 10);

      btn.setAttribute('aria-pressed', String(isActive));
      const countEl = btn.querySelector<HTMLElement>('.feedback-count');
      if (countEl) countEl.textContent = String(count);

      btn.addEventListener('click', () => {
        const wasActive = btn.getAttribute('aria-pressed') === 'true';
        const newActive = !wasActive;
        const currentCount = parseInt(localStorage.getItem(countKey) ?? '0', 10);
        const newCount = newActive ? currentCount + 1 : Math.max(0, currentCount - 1);

        localStorage.setItem(key, newActive ? '1' : '0');
        localStorage.setItem(countKey, String(newCount));

        btn.setAttribute('aria-pressed', String(newActive));
        if (countEl) countEl.textContent = String(newCount);

        // Pulse animation
        btn.style.transform = 'scale(0.95)';
        setTimeout(() => { btn.style.transform = ''; }, 120);
      });
    });

    // --- Comment toggle ---
    document.querySelectorAll('[id^="toggle-comment-"]').forEach(toggleBtn => {
      const shiurId = (toggleBtn as HTMLElement).id.replace('toggle-comment-', '');
      const formWrap = document.getElementById(`comment-form-${shiurId}`);
      if (!formWrap) return;

      toggleBtn.addEventListener('click', () => {
        const isHidden = formWrap.hidden;
        formWrap.hidden = !isHidden;
        (toggleBtn as HTMLElement).style.color = isHidden ? 'var(--blue)' : '';
      });
    });

    // --- Comment form submit (mailto) ---
    document.querySelectorAll<HTMLFormElement>('.comment-form').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const textarea = form.querySelector<HTMLTextAreaElement>('textarea');
        const comment = textarea?.value?.trim();
        if (!comment) return;

        const title = form.dataset.title ?? '';
        const email = form.dataset.email ?? '';
        const subject = encodeURIComponent(`תגובה פרטית לשיעור: ${title}`);
        const body = encodeURIComponent(`שיעור: ${title}\n\nתגובה:\n${comment}`);

        window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;

        // Show success message
        const formWrap = form.closest('.comment-form-wrap');
        if (formWrap) {
          form.hidden = true;
          const success = formWrap.querySelector<HTMLElement>('.comment-success');
          if (success) success.hidden = false;
        }
      });
    });
  }

  // Run on initial load and after navigation
  document.addEventListener('DOMContentLoaded', initFeedback);
  document.addEventListener('astro:page-load', initFeedback);
</script>
